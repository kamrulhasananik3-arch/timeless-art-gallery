        </article>
        <article class="art-card">
          <img src="assets/thumbs/img04.jpg" alt="Guernica" loading="lazy" width="1200" height="823"
            data-title="Guernica"
            data-artist="Pablo Picasso"
            data-date="1937"
            data-place="Spain"
            data-medium="Oil on canvas"
            data-dimensions="349 cm × 776 cm"
            data-license="See source page"
            data-collection="Museo Reina Sofía, Madrid"
            data-photographer="Digitized by: Museo Reina Sofía / Wikimedia Commons"
            data-description="A large-scale monochrome mural depicting the tragedies of war and suffering."
            data-license_url="https://commons.wikimedia.org/wiki/File:Guernica.jpg" />
          <div class="art-meta">
            <span>Modern</span>
            <h4>Guernica</h4>
            <p>Pablo Picasso · 1937 · Source: <a href="https://commons.wikimedia.org/wiki/File:Guernica.jpg" target="_blank" rel="noopener noreferrer">Wikimedia Commons</a></p>
          </div>
        </article>
        <article class="art-card">
          <img src="https://upload.wikimedia.org/wikipedia/commons/0/0a/The_Great_Wave_off_Kanagawa.jpg" alt="The Great Wave off Kanagawa" loading="lazy" width="1024" height="683"
            data-title="The Great Wave"
            data-artist="Katsushika Hokusai"
            data-date="c. 1831"
            data-place="Japan"
            data-medium="Polychrome woodblock print"
            data-dimensions="approx. 25.7 cm × 37.9 cm"
            data-license="Public domain"
            data-collection="Various collections / Wikimedia Commons"
            data-photographer="Digitized by: Wikimedia Commons contributors"
            data-description="Iconic ukiyo-e print depicting a massive wave threatening boats off Kanagawa."
            data-license_url="https://commons.wikimedia.org/wiki/File:The_Great_Wave_off_Kanagawa.jpg" />
          <div class="art-meta">
            <span>Ukiyo-e</span>
            <h4>The Great Wave</h4>
            <p>Katsushika Hokusai · c. 1831 · Source: <a href="https://commons.wikimedia.org/wiki/File:The_Great_Wave_off_Kanagawa.jpg" target="_blank" rel="noopener noreferrer">Wikimedia Commons</a></p>
          </div>
        </article>
        <article class="art-card">
          <img src="https://upload.wikimedia.org/wikipedia/en/d/dd/The_Persistence_of_Memory.jpg" alt="The Persistence of Memory" loading="lazy" width="1200" height="800"
            data-title="The Persistence of Memory"
            data-artist="Salvador Dalí"
            data-date="1931"
            data-place="Spain"
            data-medium="Oil on canvas"
            data-dimensions="24 cm × 33 cm"
            data-license="See source page"
            data-collection="Museum of Modern Art / Dalí Foundation (varies)"
            data-photographer="Digitized by: Wikimedia Commons contributors"
            data-description="Surrealist work famous for its melting clocks reflecting the fluidity of time."
            data-license_url="https://commons.wikimedia.org/wiki/File:The_Persistence_of_Memory.jpg" />
          <div class="art-meta">
            <span>Surrealism</span>
            <h4>The Persistence of Memory</h4>
            <p>Salvador Dali · 1931 · Source: <a href="https://commons.wikimedia.org/wiki/File:The_Persistence_of_Memory.jpg" target="_blank" rel="noopener noreferrer">Wikimedia Commons</a></p>
          </div>
        </article>

        <!-- Additional homepage photos with metadata -->
        <article class="art-card">
          <img src="https://upload.wikimedia.org/wikipedia/commons/d/da/Taj_Mahal_in_March_2004.jpg" alt="Taj Mahal (Wonders of the World)" loading="lazy" width="1024" height="682"
            data-title="Taj Mahal"
            data-artist="Ustad Ahmad Lahauri (attributed)"
            data-date="c. 1653"
            data-place="Agra, India"
            data-medium="Marble mausoleum (architecture)"
            data-dimensions="Height: approx. 73 m"
            data-license="See source page"
            data-photographer="Wikimedia Commons contributor"
            data-collection="UNESCO World Heritage Site"
            data-description="Iconic Mughal-era mausoleum built by Shah Jahan in memory of Mumtaz Mahal."
            data-license_url="https://commons.wikimedia.org/wiki/File:Taj_Mahal_in_March_2004.jpg" />
          <div class="art-meta">
            <span>Wonder of the World</span>
            <h4>Taj Mahal</h4>
            <p>Agra, India · c. 1653 · Marble mausoleum · Source: <a href="https://commons.wikimedia.org/wiki/File:Taj_Mahal_in_March_2004.jpg" target="_blank" rel="noopener noreferrer">Wikimedia Commons</a></p>
          </div>
        </article>
        <article class="art-card">
          <img src="assets/placeholder.svg" alt="Machu Picchu" loading="lazy" width="1024" height="683"
            data-title="Machu Picchu"
            data-artist="Inca (architectural site)"
            data-date="15th century"
            data-place="Cusco Region, Peru"
            data-medium="Inca stone architecture"
            data-dimensions="Site area variable"
            data-license="See source page" />
          <div class="art-meta">
            <span>Inca</span>
            <h4>Machu Picchu</h4>
            <p>Cusco Region, Peru · 15th century · Source: <a href="https://commons.wikimedia.org/wiki/File:Machu_Picchu,_Peru.jpg" target="_blank" rel="noopener noreferrer">Wikimedia Commons</a></p>
          </div>
        </article>
        <article class="art-card">
          <img src="assets/placeholder.svg" alt="Great Wall of China" loading="lazy" width="1024" height="683"
