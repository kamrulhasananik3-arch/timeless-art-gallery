<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Timeless Art Gallery</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Space+Grotesk:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="styles.css">
  <meta name="description" content="Timeless Art Gallery — curated exhibitions, artist profiles, and an open submissions gallery.">
</head>
<body>

  <header>
    <div class="brand">
      <img src="assets/logo.svg" alt="Timeless Art Gallery logo" width="160" height="160" />
      <h1>Timeless Art Gallery</h1>
      <nav>
        <a href="index.html">Home</a>
        <a href="gallery.html">Gallery</a>
        <a href="explore.html">Explore</a>
        <a href="artists.html">Artists</a>
        <a href="information.html">Information</a>
        <a href="upload.html">Upload</a>
      </nav>
    </div>
  </header>

  <section class="hero">
    <div>
      <h2>Curated art, timeless stories, and modern voices.</h2>
      <p>Explore a living gallery that pairs historic masterworks with emerging contemporary perspectives.</p>
      <div class="hero-actions">
        <a class="btn" href="gallery.html">Start Browsing</a>
        <a class="btn secondary" href="artists.html">Meet the Artists</a>
      </div>
    </div>
    <div class="hero-card">
      <span>Current Focus</span>
      <h3>Light, Surface, Memory</h3>
      <p>A rotating exhibition on how artists across centuries render atmosphere and emotion.</p>
      <div class="stats">
        <div class="stat">
          <strong>28</strong>
          <span>Featured works</span>
        </div>
        <div class="stat">
          <strong>9</strong>
          <span>Studios</span>
        </div>
        <div class="stat">
          <strong>6</strong>
          <span>Essays</span>
        </div>
      </div>
    </div>
  </section>

  <main class="content">
    <section class="feature-grid">
      <article class="feature-card">
        <h4>Curated Exhibitions</h4>
        <p>Seasonal collections curated to highlight craft, context, and bold experimentation.</p>
      </article>
      <article class="feature-card">
        <h4>Artist Profiles</h4>
        <p>Learn the stories and studios behind the work through short interviews and notes.</p>
      </article>
      <article class="feature-card">
        <h4>Open Submissions</h4>
        <p>Upload your work and join the next rotation alongside global creators.</p>
      </article>
      <article class="feature-card">
        <h4>Learning Notes</h4>
        <p>Contextual essays and timelines for deeper understanding of each movement.</p>
      </article>
    </section>

    <section class="collection">
      <div class="collection-header">
        <h3>Highlights from the collection</h3>
        <p>Six pieces chosen to represent the breadth of mediums and time periods featured this season.</p>
      </div>
      <div class="art-grid">
        <article class="art-card">
          <img src="assets/thumbs/img01.jpg" alt="Mona Lisa" loading="lazy" width="800" height="1000"
            data-title="Mona Lisa"
            data-artist="Leonardo da Vinci"
            data-date="c. 1503–1506"
            data-place="Florence, Italy"
            data-medium="Oil on poplar panel"
            data-dimensions="77 cm × 53 cm"
            data-license="Public domain (digitized)"
            data-collection="Louvre Museum, Paris"
            data-photographer="Digitized by: Musée du Louvre / Wikimedia Commons"
            data-description="Portrait of Lisa Gherardini; iconic High Renaissance portrait; noted for sfumato technique."
            data-license_url="https://commons.wikimedia.org/wiki/File:Mona_Lisa.jpg" />
          <div class="art-meta">
            <span>Renaissance</span>
            <h4>Mona Lisa</h4>
            <p>Leonardo da Vinci · c. 1503–1506 · Source: <a href="https://commons.wikimedia.org/wiki/File:Mona_Lisa.jpg" target="_blank" rel="noopener noreferrer">Wikimedia Commons</a></p>
          </div>
        </article>
        <article class="art-card">
          <img src="assets/thumbs/img02.jpg" alt="The Starry Night" loading="lazy" width="1280" height="960"
            data-title="The Starry Night"
            data-artist="Vincent van Gogh"
            data-date="1889"
            data-place="Saint-Rémy, France"
            data-medium="Oil on canvas"
            data-dimensions="73.7 cm × 92.1 cm"
            data-license="Public domain (digitized)"
            data-collection="Museum of Modern Art (MoMA), New York"
            data-photographer="Digitized by: Google Art Project / MoMA"
            data-description="A nocturnal study of swirling skies over a village; one of van Gogh's most famous works."
            data-license_url="https://commons.wikimedia.org/wiki/File:Van_Gogh_-_Starry_Night_-_Google_Art_Project.jpg" />
          <div class="art-meta">
            <span>Post-Impressionism</span>
            <h4>The Starry Night</h4>
            <p>Vincent van Gogh · 1889 · Source: <a href="https://commons.wikimedia.org/wiki/File:Van_Gogh_-_Starry_Night_-_Google_Art_Project.jpg" target="_blank" rel="noopener noreferrer">Wikimedia Commons</a></p>
          </div>
        </article>
        <article class="art-card">
          <img src="assets/thumbs/img03.jpg" alt="The Water Lily Pond" loading="lazy" width="1024" height="683"
            data-title="The Water Lily Pond"
            data-artist="Claude Monet"
            data-date="1899"
            data-place="Giverny, France"
            data-medium="Oil on canvas"
            data-dimensions="approx. 100 cm × 180 cm"
            data-license="Public domain (digitized)"
            data-collection="Musée de l'Orangerie / Various collections"
            data-photographer="Digitized by: Wikimedia Commons contributors"
            data-description="Part of Monet's Water Lilies series exploring light and reflection in the garden pond."
            data-license_url="https://commons.wikimedia.org/wiki/File:Claude_Monet_-_The_Water_Lily_Pond.jpg" />
          <div class="art-meta">
            <span>Impressionism</span>
            <h4>The Water Lily Pond</h4>
            <p>Claude Monet · 1899 · Source: <a href="https://commons.wikimedia.org/wiki/File:Claude_Monet_-_The_Water_Lily_Pond.jpg" target="_blank" rel="noopener noreferrer">Wikimedia Commons</a></p>
