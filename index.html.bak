            data-artist="Various builders"
            data-date="Various dynasties"
            data-place="China"
            data-medium="Fortification architecture"
            data-dimensions="Length: thousands of km (varies by section)"
            data-license="See source page" />
          <div class="art-meta">
            <span>Historic Architecture</span>
            <h4>Great Wall</h4>
            <p>China · Various dynasties · Source: <a href="https://commons.wikimedia.org/wiki/File:Great_Wall_of_China_July_2006.JPG" target="_blank" rel="noopener noreferrer">Wikimedia Commons</a></p>
          </div>
        </article>
        <article class="art-card">
          <img src="assets/placeholder.svg" alt="Chichen Itza" loading="lazy" width="1024" height="768" data-title="Chichen Itza" data-artist="Maya (architectural site)" data-date="c. 600–1200 CE" data-place="Yucatán, Mexico" data-source="https://commons.wikimedia.org/wiki/File:Chichen_Itza_El_Castillo_2013.jpg" />
          <div class="art-meta">
            <span>Mesoamerican</span>
            <h4>Chichen Itza</h4>
            <p>Yucatán, Mexico · c. 600–1200 CE · Source: <a href="https://commons.wikimedia.org/wiki/File:Chichen_Itza_El_Castillo_2013.jpg" target="_blank" rel="noopener noreferrer">Wikimedia Commons</a></p>
          </div>
        </article>
        <article class="art-card">
          <img src="assets/placeholder.svg" alt="Colosseum" loading="lazy" width="1024" height="683" data-title="Colosseum" data-artist="Ancient Roman builders" data-date="AD 72–80" data-place="Rome, Italy" data-source="https://commons.wikimedia.org/wiki/File:Colosseum_in_Rome,_Italy_-_April_2007.jpg" />
          <div class="art-meta">
            <span>Ancient Rome</span>
            <h4>Colosseum</h4>
            <p>Rome, Italy · AD 72–80 · Source: <a href="https://commons.wikimedia.org/wiki/File:Colosseum_in_Rome,_Italy_-_April_2007.jpg" target="_blank" rel="noopener noreferrer">Wikimedia Commons</a></p>
          </div>
        </article>
      </div>

      <!-- Image detail modal -->
      <div id="imageModal" class="modal" aria-hidden="true">
        <div class="modal-backdrop" id="modalBackdrop"></div>
        <div class="modal-content" role="dialog" aria-modal="true" aria-labelledby="modalTitle">
          <button class="modal-close" id="modalClose" aria-label="Close">×</button>
          <img id="modalImage" src="" alt="" />
          <div class="modal-meta">
            <h4 id="modalTitle"></h4>
            <p id="modalArtist"></p>
            <p id="modalDate"></p>
            <p id="modalPlace"></p>
            <p id="modalSource"></p>
          </div>
        </div>
      </div>

      <script>
        (function(){
          const modal = document.getElementById('imageModal');
          const modalImage = document.getElementById('modalImage');
          const modalTitle = document.getElementById('modalTitle');
          const modalArtist = document.getElementById('modalArtist');
          const modalDate = document.getElementById('modalDate');
          const modalPlace = document.getElementById('modalPlace');
          const modalSource = document.getElementById('modalSource');
          const modalClose = document.getElementById('modalClose');
          const modalBackdrop = document.getElementById('modalBackdrop');
          const modalContent = document.querySelector('.modal-content');

          function openModal(img){
            // Prefer a Wikimedia thumbnail variant for the modal to improve reliability and size.
            let modalSrc = img.src || '';
            try {
              const m = modalSrc.match(/(https:\/\/upload\.wikimedia\.org\/wikipedia\/)([^\/]+)\/(.+)$/);
              if (m) {
                const prefix = m[1];
                const lang = m[2];
                const rest = m[3];
                const parts = rest.split('/');
                const basename = parts[parts.length-1];
                const size = 1024;
                modalSrc = prefix + lang + '/thumb/' + parts.slice(0).join('/') + '/' + size + 'px-' + basename;
              }
            } catch (e) {}
            modalImage.src = modalSrc;
            modalImage.alt = img.alt || '';
            modalTitle.textContent = img.dataset.title || img.alt || '';
            modalArtist.textContent = img.dataset.artist ? 'Artist: ' + img.dataset.artist : '';
            modalDate.textContent = img.dataset.date ? 'Date: ' + img.dataset.date : '';
            modalPlace.textContent = img.dataset.place ? 'Place: ' + img.dataset.place : '';
            modalSource.innerHTML = img.dataset.source ? 'Source: <a href="'+img.dataset.source+'" target="_blank" rel="noopener noreferrer">Wikimedia Commons</a>' : '';
            // show modal (use aria-hidden + CSS transitions)
            modal.setAttribute('aria-hidden','false');
            document.body.style.overflow = 'hidden';
          }

          function closeModal(){
            // start hide animation by setting aria-hidden true
            modal.setAttribute('aria-hidden','true');
            document.body.style.overflow = '';
          }

          // after hide transition, clear image src to free memory
          modalContent.addEventListener('transitionend', (e) => {
            if (modal.getAttribute('aria-hidden') === 'true' && e.propertyName === 'opacity') {
              modalImage.src = '';
            }
          });

          // fallback for modal image load failures
          modalImage.addEventListener('error', () => {
            if (!modalImage.dataset._errored) {
              modalImage.dataset._errored = '1';
              modalImage.src = 'assets/placeholder.svg';
            }
          });

          document.querySelectorAll('.art-card img').forEach(img => {
            img.style.cursor = 'zoom-in';
            img.addEventListener('click', () => openModal(img));
            img.addEventListener('error', () => {
              // Robust retry strategy for transient failures (429 / rate limits).
              if (!img.dataset.origSrc) img.dataset.origSrc = img.src || '';
              const orig = img.dataset.origSrc;
              const attempts = parseInt(img.dataset.attempts || '0', 10);
              const maxAttempts = 4;
              if (attempts >= maxAttempts) {
                img.src = 'assets/placeholder.svg';
                img.alt = 'Placeholder image';
                return;
              }
              img.dataset.attempts = String(attempts + 1);

              // If this looks like a Wikimedia URL, try a thumbnail variant first.
              const isWikimedia = /https:\/\/upload\.wikimedia\.org\//.test(orig);
              if (isWikimedia && !img.dataset.triedThumb) {
                img.dataset.triedThumb = '1';
                try {
                  const m = orig.match(/(https:\/\/upload\.wikimedia\.org\/wikipedia\/)([^\/]+)\/(.+)$/);
                  if (m) {
                    const prefix = m[1];
                    const lang = m[2];
                    const rest = m[3];
                    const parts = rest.split('/');
                    const basename = parts[parts.length-1];
                    const size = Math.min(1024, Math.max(300, Math.round((img.width||600))));
                    const thumb = prefix + lang + '/thumb/' + parts.slice(0).join('/') + '/' + size + 'px-' + basename;
                    // try thumb variant immediately
                    img.src = thumb;
                    // allow further error events to trigger retries, so return here
                    return;
                  }
                } catch (e) {}
              }

              // For transient rate limits (429) we retry after delays. Use exponential backoff.
              const backoff = [800, 2000, 6000, 15000];
              const delay = backoff[Math.min(attempts, backoff.length-1)];
              setTimeout(() => {
                // retry original URL (or the thumb we previously set)
                img.src = orig;
              }, delay);
            });
          });
          });

          modalClose.addEventListener('click', closeModal);
          modalBackdrop.addEventListener('click', closeModal);
          document.addEventListener('keydown', (e) => { if(e.key === 'Escape') closeModal(); });
        })();
      </script>
    </section>

    <section class="cta">
      <div>
        <h4>Submit your work to the next drop</h4>
        <p>We highlight emerging voices every season. Share your portfolio and join the collection.</p>
      </div>
      <a class="btn" href="upload.html">Upload Your Art</a>
    </section>
  </main>

  <footer>
    © 2026 Timeless Art Gallery — Celebrating Beauty in Every Brushstroke
  </footer>
</body>
</html>
